<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Nitrogen.Views.Settings.DsPumpSet"
        Title="DsPumpSet">
  
    <Grid Background="{DynamicResource PrimaryGridColor}">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="1*"/>
			<ColumnDefinition Width="1*"/>
		</Grid.ColumnDefinitions>
		<Grid.RowDefinitions>
			<RowDefinition Height="1*"/>
			<RowDefinition Height="5*"/>
			<RowDefinition Height="2*"/>
		</Grid.RowDefinitions>

		<!-- Header -->
		<Grid Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="2" Background="{DynamicResource PrimaryHeaderBrush}">
			<TextBlock  Classes="section_label" Text="Настройка Насоса ВС"/>
		</Grid>

		<!-- Настройка частоты  -->
		<Border Grid.Column="0" Grid.Row="1">
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="1*"/>
					<RowDefinition Height="1*"/>
					<RowDefinition Height="1*"/>
					<RowDefinition Height="1*"/>
					<RowDefinition Height="1*"/>
					<RowDefinition Height="1*"/>
				</Grid.RowDefinitions>

				<!-- Герц Мин.. -->
				<TextBlock Grid.Row="0" Classes="section_label"
						   Text="Мин. Гц"/>
				<Grid Grid.Row="1">
					<TextBox Text="0"/>
					<TextBlock Classes="hotkey" Text="F3"/>
				</Grid>

				<!-- Герц Макс.. -->
				<TextBlock Grid.Row="2" Classes="section_label"
						   Text="Макс. Гц"/>
				<Grid Grid.Row="3">
					<TextBox Text="1000"/>
					<TextBlock Classes="hotkey" Text="F4"/>
				</Grid>

				<!-- Текущие Значения -->
				<TextBlock Grid.Row="4" Classes="menu_title" Background="Red" Text="300 bpm"/>

			</Grid>
		</Border>

		<!-- Настройка Значений -->
		<Border Grid.Column="1" Grid.Row="1">
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="1*"/>
					<RowDefinition Height="1*"/>
					<RowDefinition Height="1*"/>
					<RowDefinition Height="1*"/>
					<RowDefinition Height="1*"/>
					<RowDefinition Height="1*"/>
				</Grid.RowDefinitions>

				<!-- BPM Мин.. -->
				<TextBlock Grid.Row="0" Classes="section_label"
						   Text="Мин. bpm"/>
				<Grid Grid.Row="1">
					<TextBox Text="0.00"/>
					<TextBlock Classes="hotkey" Text="F5"/>
				</Grid>

				<!-- BPM Макс.. -->
				<TextBlock Grid.Row="2" Classes="section_label"
						   Text="Макс. bpm"/>
				<Grid Grid.Row="3">
					<TextBox Text="10"/>
					<TextBlock Classes="hotkey" Text="F6"/>
				</Grid>
			</Grid>
		</Border>

		<!-- Блок Кнопок -->
		<Grid Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="2">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="1*"/>
				<ColumnDefinition Width="1*"/>
				<ColumnDefinition Width="1*"/>
			</Grid.ColumnDefinitions>

			<!-- Сохранить -->
			<Button x:Name="Save" Grid.Column="0" >
				<Grid>
					<TextBlock Classes="menu_title" Text="Сохранить"/>
					<TextBlock Classes="hotkey" Text="F1"/>
				</Grid>
			</Button>

			<!-- Заглушка -->
			<Border Grid.Column="1">

			</Border>

			<!-- Выход -->
			<Button x:Name="Exit" Grid.Column="2"  Click="Exit_Click">
				<Grid>
					<TextBlock Classes="menu_title" Text="Выход"/>
					<TextBlock Classes="hotkey" Text="ESC"/>
				</Grid>
			</Button>
		</Grid>
	</Grid>
</Window>
