<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Nitrogen.Views.Settings.SettingsControl">
  
    <Grid Background="{DynamicResource PrimaryGridColor}" >
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="1*"/>
			<ColumnDefinition Width="1*"/>
			<ColumnDefinition Width="1*"/>
		</Grid.ColumnDefinitions>
		<Grid.RowDefinitions>
			<RowDefinition Height="1*"/>
			<RowDefinition Height="1*"/>
			<RowDefinition Height="1*"/>
		</Grid.RowDefinitions>

		<!-- Давление -->
		<Button x:Name="PressureCalli" Grid.Column="0" Grid.Row="0" Click="PressureCalli_Click">
			<Grid>
				<TextBlock Classes="menu_title" TextAlignment="Center">
					<Run Text="Настройка"/>
					<LineBreak/>
					<Run Text="Давления"/>
				</TextBlock>
				<TextBlock Classes="hotkey" Text="F1"/>
			</Grid>
		</Button>

		<!-- ВС Насос -->
		<Button x:Name="DsPumpCalli" Grid.Column="1" Grid.Row="1" Click="DsPumpCalli_Click">
			<Grid>
				<TextBlock Classes="menu_title" TextAlignment="Center">
					<Run Text="Настройка"/>
					<LineBreak/>
					<Run Text="ВС Насос"/>
				</TextBlock>
				<TextBlock Classes="hotkey" Text="F5"/>
			</Grid>
		</Button>

		<!-- ПС Насос -->
		<Button x:Name="PsPumpCalli" Grid.Column="1" Grid.Row="2" Click="PsPumpCalli_Click">
			<Grid>
				<TextBlock Classes="menu_title" TextAlignment="Center">
					<Run Text="Настройка"/>
					<LineBreak/>
					<Run Text="ПС Насос"/>
				</TextBlock>
				<TextBlock Classes="hotkey" Text="F6"/>
			</Grid>
		</Button>

		<!-- Выход Меню -->
		<Button x:Name="Exit" Grid.Column="2" Grid.Row="2" Click="Exit_Click">
			<Grid>
				<TextBlock Classes="menu_title" Text="Выход"/>

				<TextBlock Classes="hotkey" Text="ESC"/>
			</Grid>
		</Button>
	</Grid>
</UserControl>
