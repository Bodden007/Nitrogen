<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
		x:Class="Nitrogen.Temperature"
		Title="Temperature">

	<Grid Background="{DynamicResource PrimaryGridColor}">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="1*"/>
			<ColumnDefinition Width="1*"/>
		</Grid.ColumnDefinitions>
		<Grid.RowDefinitions>
			<RowDefinition Height="1*"/>
			<RowDefinition Height="5*"/>
			<RowDefinition Height="2*"/>
		</Grid.RowDefinitions>

		<!-- Header -->
		<Grid Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="2" Background="{DynamicResource PrimaryHeaderBrush}">
			<TextBlock Classes="StyleTag" Text="Температура"/>
		</Grid>

		<!-- Температура Выход -->
		<Border Grid.Column="0" Grid.Row="1">
		
		</Border>

		<!-- Температура Вапарайзер и баня -->
		<Border Grid.Column="1" Grid.Row="1">
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="1*"/>
					<RowDefinition Height="1*"/>
				</Grid.RowDefinitions>

				<Border Grid.Row="0">
				
				</Border>

				<Border Grid.Row="1">
				
				</Border>

			</Grid>

			
			
		</Border>


		<!-- Заглушка -->
		<Border Grid.Column="0" Grid.Row="2">
			
		</Border>

		<!-- Выход -->
		<Button x:Name="Exit" Grid.Column="1" Grid.Row="2" Click="Exit_Click">
			<Grid>
				<TextBlock Classes="StyleTextBlock_2" Text="Выход"/>
				<TextBlock Classes="FTextBlock" Text="ESC"/>
			</Grid>
		</Button>

	</Grid>
</Window>
