<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Nitrogen.Views.Menu.TemperatureControl">
  
    <Grid Background="{DynamicResource PrimaryGridColor}">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="1*"/>
			<ColumnDefinition Width="1*"/>
		</Grid.ColumnDefinitions>
		<Grid.RowDefinitions>
			<RowDefinition Height="1*"/>
			<RowDefinition Height="5*"/>
			<RowDefinition Height="2*"/>
		</Grid.RowDefinitions>

		<!-- Header -->
		<Grid Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="2" Background="{DynamicResource PrimaryHeaderBrush}">
			<TextBlock Classes="section_label" Text="Температура"/>
		</Grid>

		<!-- Температура Выход -->
		<Border Grid.Column="0" Grid.Row="1">
			<Grid>
				<TextBlock Classes="menu_title"
						   VerticalAlignment="Top"
						   Text="На Выходе" />
				<TextBlock/>
				<TextBlock Classes="menu_title"
						   VerticalAlignment="Center"
						   Background="BlueViolet"
						   Text="40 °C"/>
			</Grid>
		</Border>

		<!-- Температура Вапарайзер и баня -->
		<Grid Grid.Column="1" Grid.Row="1">
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="1*"/>
					<RowDefinition Height="1*"/>
				</Grid.RowDefinitions>

				<Border Grid.Row="0">
					<Grid>
						<TextBlock Classes="menu_title"
								   VerticalAlignment="Top"
								   Text="Вапорайзера" />
						<TextBlock/>
						<TextBlock Classes="menu_title"
								   VerticalAlignment="Center"
								   Background="BlueViolet"
								   Text="38 °C"/>
					</Grid>

				</Border>

				<Border Grid.Row="1">
					<Grid>
						<TextBlock Classes="menu_title"
								   VerticalAlignment="Top"
								   Text="Теплообенника" />
						<TextBlock/>
						<TextBlock Classes="menu_title"
								   VerticalAlignment="Center"
								   Background="BlueViolet"
								   Text="70 °C"/>
					</Grid>
				</Border>

			</Grid>

		</Grid>


		<!-- Заглушка -->
		<Border Grid.Column="0" Grid.Row="2">

		</Border>

		<!-- Выход -->
		<Button x:Name="Exit" Grid.Column="1" Grid.Row="2" Click="Exit_Click">
			<Grid>
				<TextBlock Classes="menu_title" Text="Выход"/>
				<TextBlock Classes="hotkey" Text="ESC"/>
			</Grid>
		</Button>

	</Grid>
</UserControl>
