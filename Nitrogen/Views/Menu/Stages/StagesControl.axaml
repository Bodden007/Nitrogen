<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:Class="Nitrogen.Views.Menu.StagesControl">

	<Grid Background="{DynamicResource PrimaryGridColor}">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="1*"/>
			<ColumnDefinition Width="1*"/>
			<ColumnDefinition Width="1*"/>
			<ColumnDefinition Width="1*"/>
		</Grid.ColumnDefinitions>
		<Grid.RowDefinitions>
			<RowDefinition Height="1*"/>
			<RowDefinition Height="1*"/>
			<RowDefinition Height="1*"/>
			<RowDefinition Height="1*"/>
			<RowDefinition Height="1*"/>
			<RowDefinition Height="1*"/>
			<RowDefinition Height="2*"/>
		</Grid.RowDefinitions>

		<!-- Header -->
		<Grid Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="4" Background="{DynamicResource PrimaryHeaderBrush}">
			<TextBlock  Classes="section_label"
						Text="Стадии"/>
		</Grid>

		<!-- Блок кнопок выбора стадий -->
		<!-- 1 -->
		<Button Grid.Column="0" Grid.Row="1">
			<Grid>
				<TextBlock Classes="menu_subtext"
						   Text="Стад 1"/>
				<TextBlock Classes="hotkey" Text="ctrl 1" />
			</Grid>
		</Button>

		<!-- 2 -->
		<Button Grid.Column="0" Grid.Row="2">
			<Grid>
				<TextBlock Classes="menu_subtext"
						   Text="Стад 2"/>
				<TextBlock Classes="hotkey" Text="ctrl 2" />
			</Grid>
		</Button>

		<!-- 3 -->
		<Button Grid.Column="0" Grid.Row="3">
			<Grid>
				<TextBlock Classes="menu_subtext"
						   Text="Стад 3"/>
				<TextBlock Classes="hotkey" Text="ctrl 3" />
			</Grid>
		</Button>

		<!-- 4 -->
		<Button Grid.Column="0" Grid.Row="4">
			<Grid>
				<TextBlock Classes="menu_subtext"
						   Text="Стад 4"/>
				<TextBlock Classes="hotkey" Text="ctrl 4" />
			</Grid>
		</Button>

		<!-- 5 -->
		<Button Grid.Column="0" Grid.Row="5">
			<Grid>
				<TextBlock Classes="menu_subtext"
						   Text="Стад 5"/>
				<TextBlock Classes="hotkey" Text="ctrl 5" />
			</Grid>
		</Button>

		<!-- 6 -->
		<Button Grid.Column="1" Grid.Row="1">
			<Grid>
				<TextBlock Classes="menu_subtext"
						   Text="Стад 6"/>
				<TextBlock Classes="hotkey" Text="ctrl 6" />
			</Grid>
		</Button>

		<!-- 7 -->
		<Button Grid.Column="1" Grid.Row="2">
			<Grid>
				<TextBlock Classes="menu_subtext"
						   Text="Стад 7"/>
				<TextBlock Classes="hotkey" Text="ctrl 7" />
			</Grid>
		</Button>

		<!-- 8 -->
		<Button Grid.Column="1" Grid.Row="3">
			<Grid>
				<TextBlock Classes="menu_subtext"
						   Text="Стад 8"/>
				<TextBlock Classes="hotkey" Text="ctrl 8" />
			</Grid>
		</Button>

		<!-- 9 -->
		<Button Grid.Column="1" Grid.Row="4">
			<Grid>
				<TextBlock Classes="menu_subtext"
						   Text="Стад 9"/>
				<TextBlock Classes="hotkey" Text="ctrl 9" />
			</Grid>
		</Button>

		<!-- 10 -->
		<Button Grid.Column="1" Grid.Row="5">
			<Grid>
				<TextBlock Classes="menu_subtext"
						   Text="Стад 10"/>
				<TextBlock Classes="hotkey" Text="ctrl 0" />
			</Grid>
		</Button>

		<!-- Начало стадии -->
		<Border Grid.Column="2" Grid.Row="1" Grid.ColumnSpan="2">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="1*"/>
					<ColumnDefinition Width="1*"/>
				</Grid.ColumnDefinitions>
				<TextBlock Grid.Column="0" Classes="menu_subtext"
						   Text="Начало"/>
				<TextBox Grid.Column="1" Classes="Volume"
						 Text="0"/>
				<TextBlock Grid.Column="1" Classes="hotkey"
						   Text="F4"/>
			</Grid>
		</Border>

		<!-- Конец стадии -->
		<Border Grid.Column="2" Grid.Row="2" Grid.ColumnSpan="2">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="1*"/>
					<ColumnDefinition Width="1*"/>
				</Grid.ColumnDefinitions>
				<TextBlock Grid.Column="0" Classes="menu_subtext"
						   Text="Конец"/>
				<TextBox Grid.Column="1" Classes="Volume"
						 Text="0"/>
				<TextBlock Grid.Column="1" Classes="hotkey"
						   Text="F5"/>
			</Grid>
		</Border>

		<!-- Объем стадии -->
		<Border Grid.Column="2" Grid.Row="3" Grid.ColumnSpan="2">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="1*"/>
					<ColumnDefinition Width="1*"/>
				</Grid.ColumnDefinitions>
				<TextBlock Grid.Column="0" Classes="menu_subtext"
						   Text="Объем"/>
				<TextBox Grid.Column="1" Classes="Volume"
						 Text="0"/>
				<TextBlock Grid.Column="1" Classes="hotkey"
						   Text="F6"/>
			</Grid>
		</Border>

		<!-- Давление -->
		<Border Grid.Column="2" Grid.Row="4" Grid.ColumnSpan="2" Grid.RowSpan="2">
			<Grid>
				<TextBlock Classes="menu_title" VerticalAlignment="Top" Text="Давление"/>
				<TextBlock Classes="menu_title" VerticalAlignment="Bottom" Background="Red"
						   Text="800"/>
			</Grid>
		</Border>

		<!-- Нижний Блок Кнопок -->
		<Grid Grid.Column="0" Grid.Row="6" Grid.ColumnSpan="4" >
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="1*"/>
				<ColumnDefinition Width="1*"/>
				<ColumnDefinition Width="1*"/>
				<ColumnDefinition Width="1*"/>
			</Grid.ColumnDefinitions>

			<!-- Старт -->
			<Button x:Name="Start" Grid.Column="0" >
				<Grid>
					<TextBlock Classes="menu_title" TextAlignment="Center"
							   Text="Старт"/>

					<TextBlock Classes="hotkey" Text="F1"/>
				</Grid>
			</Button>

			<!-- Пауза -->
			<Button x:Name="Pause" Grid.Column="1">
				<Grid>
					<TextBlock Classes="menu_title" TextAlignment="Center"
							   Text="Пауза"/>
					<TextBlock Classes="hotkey" Text="F2"/>
				</Grid>
			</Button>

			<!-- Стоп -->
			<Button x:Name="Stop" Grid.Column="2">
				<Grid>
					<TextBlock Classes="menu_title" TextAlignment="Center"
							   Text="Стоп"/>
					<TextBlock Classes="hotkey" Text="F3"/>
				</Grid>
			</Button>

			<!-- Выход -->
			<Button x:Name="Exit" Grid.Column="3"  Click="Exit_Click">
				<Grid>
					<TextBlock Classes="menu_title" Text="Выход"/>
					<TextBlock Classes="hotkey" Text="ESC"/>
				</Grid>
			</Button>
		</Grid>
	</Grid>
</UserControl>
