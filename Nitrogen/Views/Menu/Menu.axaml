<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
		x:Class="Nitrogen.Menu"
		Title="Menu">

	<Grid Background="{DynamicResource PrimaryGridColor}" >
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="1*"/>
			<ColumnDefinition Width="1*"/>
			<ColumnDefinition Width="1*"/>
		</Grid.ColumnDefinitions>
		<Grid.RowDefinitions>
			<RowDefinition Height="1*"/>
			<RowDefinition Height="1*"/>
			<RowDefinition Height="1*"/>
		</Grid.RowDefinitions>

		<!--Давление-->
		<Button x:Name="Pressure" Grid.Column="0" Grid.Row="0" Click="Pressure_Click">
			<Grid>
				<TextBlock Classes="StyleTextBlock_2" Text="Давление"/>
				<TextBlock Classes="FTextBlock" Text="F1"/>
			</Grid>
		</Button>

		<!--Закрыть приложение-->
		<Button x:Name="CloseApp" Grid.Column="2" Grid.Row="0" Click="CloseApp_Click">
			<Grid>
				<TextBlock Classes="StyleTextBlock_2" Text="Закрыть"/>
				<TextBlock Classes="FTextBlock" Text="F7"/>
			</Grid>
		</Button>

		<!--Выход из Меню-->
		<Button x:Name="Exit" Grid.Column="2" Grid.Row="2" Click="Exit_Click">
			<Grid>
				<TextBlock Classes="StyleTextBlock_2" Text="Выход"/>
				<TextBlock Classes="FTextBlock" Text="ESC"/>
			</Grid>
		</Button>
	</Grid>
</Window>
