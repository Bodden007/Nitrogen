<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
		x:Class="Nitrogen.Menu"
		Title="Menu">

	<Grid Background="{DynamicResource PrimaryGridColor}" >
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="1*"/>
			<ColumnDefinition Width="1*"/>
			<ColumnDefinition Width="1*"/>
		</Grid.ColumnDefinitions>
		<Grid.RowDefinitions>
			<RowDefinition Height="1*"/>
			<RowDefinition Height="1*"/>
			<RowDefinition Height="1*"/>
		</Grid.RowDefinitions>

		<!-- Давление -->
		<Button x:Name="Pressure" Grid.Column="0" Grid.Row="0" Click="Pressure_Click">
			<Grid>
				<TextBlock Classes="StyleTextBlock_2" Text="Давление"/>
				<TextBlock Classes="FTextBlock" Text="F1"/>
			</Grid>
		</Button>

		<!-- Температура -->
		<Button x:Name="Temperature" Grid.Column="0" Grid.Row="1" Click="Temperature_Click">
			<Grid>
				<TextBlock Classes="StyleTextBlock_2" Text="Температура"/>
				<TextBlock Classes="FTextBlock" Text="F2"/>
			</Grid>
		</Button>

		<!-- Объем -->
		<Button x:Name="Volume" Grid.Column="1" Grid.Row="0" Click="Volume_Click">
			<Grid>
				<TextBlock Classes="StyleTextBlock_2" TextAlignment="Center" >
					<Run Text="Объем"/>
					<LineBreak/>
					<Run Text="Цемента"/>
				</TextBlock>
				<TextBlock Classes="FTextBlock" Text="F4"/>
			</Grid>
		</Button>

		<!-- Двигатель -->
		<Button x:Name="Engine" Grid.Column="1" Grid.Row="1" Click="Engine_Click">
			<Grid>
				<TextBlock Classes="StyleTextBlock_2" TextAlignment="Center"
						   Text="Двигатель"/>
				<TextBlock Classes="FTextBlock" Text="F5"/>
			</Grid>
		</Button>

		<!-- Закрыть приложение -->
		<Button x:Name="CloseApp" Grid.Column="2" Grid.Row="0" Click="CloseApp_Click">
			<Grid>
				<TextBlock Classes="StyleTextBlock_2" Text="Закрыть"/>
				<TextBlock Classes="FTextBlock" Text="F7"/>
			</Grid>
		</Button>

		<!-- Настройки приложение -->
		<Button x:Name="Settings" Grid.Column="2" Grid.Row="1" Click="Settings_Click">
			<Grid>
				<TextBlock Classes="StyleTextBlock_2" Text="Настройки"/>
				<TextBlock Classes="FTextBlock" Text="F8"/>
			</Grid>
		</Button>

		<!--Выход из Меню-->
		<Button x:Name="Exit" Grid.Column="2" Grid.Row="2" Click="Exit_Click">
			<Grid>
				<TextBlock Classes="StyleTextBlock_2" Text="Выход"/>
				<TextBlock Classes="FTextBlock" Text="ESC"/>
			</Grid>
		</Button>
	</Grid>
</Window>
